<div style="margin:0; padding:0; background-color:#0d0d0d; font-family:Arial, Helvetica, sans-serif; width:100%;">

  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="padding:40px 0; background-color:#0d0d0d;">
    <tr>
      <td align="center">

        <table width="650" cellpadding="0" cellspacing="0" border="0"
          style="background-color:#111111; border-radius:18px; overflow:hidden; border:1px solid #2a2a2a;">

          <!-- Banner -->
          <tr>
            <td>
              <img
                src="https://res.cloudinary.com/dmwy7wbh7/image/upload/q_auto/f_auto/v1778841139/Email.Via3_qnmftt.png"
                alt="ViaCore"
                width="650"
                style="display:block; width:100%; max-width:650px;"
              />
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding:50px 45px;">

              <h1 style="color:#ffffff; font-size:30px; margin:0 0 25px 0; font-weight:700;">
                Reunión Confirmada
              </h1>

              <p style="color:#d6d6d6; font-size:17px; line-height:30px; margin-bottom:25px;">
                Tu reunión ha sido programada exitosamente en la plataforma de ViaCore.
              </p>

              <div style="
                background-color:#181818;
                border-left:4px solid #d4a64f;
                padding:22px;
                border-radius:10px;
                margin:35px 0;
              ">

                <p style="margin:0 0 12px 0; color:#ffffff; font-size:16px;">
                  <strong>Fecha:</strong> {{date}}
                </p>

                <p style="margin:0; color:#ffffff; font-size:16px;">
                  <strong>Enlace Meet:</strong>
                </p>

                <a
                  href="{{meetLink}}"
                  style="
                    color:#d4a64f;
                    text-decoration:none;
                    font-size:15px;
                    word-break:break-all;
                  "
                >
                  {{meetLink}}
                </a>

              </div>

              <p style="color:#9f9f9f; font-size:15px; line-height:28px; margin-bottom:35px;">
                Te recomendamos conectarte unos minutos antes de la hora programada para garantizar el correcto inicio de la sesión.
              </p>

              <table cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" bgcolor="#d4a64f" style="border-radius:8px;">
                    <a
                      href="{{meetLink}}"
                      style="
                        display:inline-block;
                        padding:15px 35px;
                        color:#111111;
                        text-decoration:none;
                        font-size:15px;
                        font-weight:bold;
                      "
                    >
                      INGRESAR A LA REUNIÓN
                    </a>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:25px; text-align:center; background-color:#0a0a0a; border-top:1px solid #1f1f1f;">
              <p style="margin:0; color:#777777; font-size:13px; line-height:22px;">
                © {{year}} ViaCore · Todos los derechos reservados.
              </p>
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</div>