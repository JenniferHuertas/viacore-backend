<div style="margin:0; padding:0; background-color:#0d0d0d; font-family:Arial, Helvetica, sans-serif; width:100%;">

  <table
    width="100%"
    cellpadding="0"
    cellspacing="0"
    border="0"
    style="padding:40px 0; background-color:#0d0d0d;"
  >
    <tr>
      <td align="center">

        <table
          width="650"
          cellpadding="0"
          cellspacing="0"
          border="0"
          style="
            background-color:#111111;
            border-radius:18px;
            overflow:hidden;
            border:1px solid #2a2a2a;
          "
        >

          <tr>
            <td>
              <img
                src="https://res.cloudinary.com/dmwy7wbh7/image/upload/q_auto/f_auto/v1778841139/Email.Via3_qnmftt.png"
                alt="ViaCore"
                width="650"
                style="display:block; width:100%; max-width:650px;"
              />
            </td>
          </tr>

          <tr>
            <td style="padding:50px 45px;">

              <h1 style="
                color:#ffffff;
                font-size:32px;
                margin:0 0 25px 0;
                font-weight:700;
              ">
                Solicitud en revisión
              </h1>

              <p style="
                color:#d6d6d6;
                font-size:17px;
                line-height:30px;
              ">
                Hola {{fullName}}, tu solicitud está siendo evaluada por el equipo de ViaCore.
              </p>

            </td>
          </tr>

          <tr>
            <td style="
              padding:25px;
              text-align:center;
              background-color:#0a0a0a;
              border-top:1px solid #1f1f1f;
            ">
              <p style="
                margin:0;
                color:#777777;
                font-size:13px;
              ">
                © {{year}} ViaCore · Todos los derechos reservados.
              </p>
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</div>