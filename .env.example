# ==========================================
# 1. BASE DE DATOS
# ==========================================
DB_HOST=tu_host_de_base_de_datos
DB_PORT=5432
DB_USERNAME=tu_usuario_de_postgres
DB_PASSWORD=tu_contraseña_de_base_de_datos
DB_NAME=postgres

# ==========================================
# 2. AUTENTICACIÓN Y SEGURIDAD
# ==========================================
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000

# Llave secreta para firmar los tokens de sesión de los usuarios (JWT)
JWT_SECRET=tu_palabra_secreta_jwt

# Configuración del Login con Google (Google Auth)
GOOGLE_CLIENT_ID=tu_google_client_id
GOOGLE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8000/auth/google/callback

# ==========================================
# 3. INTELIGENCIA ARTIFICIAL
# ==========================================
GROQ_API_KEY=tu_api_key_aqui

# ==========================================
# 4. ENVÍO DE CORREOS AUTOMÁTICOS (Brevo API)
# ==========================================

BREVO_API_KEY=tu_brevo_api_key
BREVO_SENDER_EMAIL=tu_correo_de_brevo@gmail.com
PLATFORM_URL=https://tu_url_produccion/

# ==========================================
# 5. ALMACENAMIENTO DE IMÁGENES (Cloudinary)
# ==========================================
CLOUDINARY_CLOUD_NAME=tu_cloudinary_cloud_name
CLOUDINARY_API_KEY=tu_cloudinary_api_key
CLOUDINARY_API_SECRET=tu_cloudinary_api_secret

# ==========================================
# 6. BASE DE DATOS EN CACHÉ (Redis)
# ==========================================
REDIS_URL=redis://default:tu_token_redis@host:puerto

# ==========================================
# 7. NOTIFICACIONES PUSH O ADICIONALES (Firebase)
# ==========================================
FIREBASE_CONFIG_PATH=firebase-service-account.json

# ==========================================
# 8. PASARELA DE PAGOS (Culqui)
# ==========================================
MP_ACCESS_TOKEN=tu_mercado_pago_access_token
MP_WEBHOOK_SECRET=tu_mercado_pago_webhook_secret

# ==========================================
# 9. AGENDA (Google Meet)
# ==========================================
GOOGLE_MEET_CLIENT_ID=tu_google_client_id
GOOGLE_MEET_CLIENT_SECRET=tu_google_client_secret
GOOGLE_MEET_REFRESH_TOKEN=aqui_va_el_token

# ==========================================
# 10. LLAVES GENÉRICAS / ANTIGUAS
# ==========================================
API_KEY=tu_api_key
API_SECRET=tu_api_secret